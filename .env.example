POSTGRES_DB=committr
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/committr
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
# Optional: set true to write Redis key "test"=hello on startup (see committr.session.redis-startup-test in application.yaml)
# COMMITTR_SESSION_REDIS_STARTUP_TEST=true

# 32-byte AES-256 key: exactly 32 UTF-8 characters or Base64 that decodes to 32 bytes.
# Docker Compose injects a dev default if unset/empty; set your own for real deploys (e.g. openssl rand -base64 32).
ENCRYPTION_KEY=12345678901234567890123456789012

# Session cookie: set true behind HTTPS in production
SESSION_COOKIE_SECURE=false

# GitHub OAuth App: https://github.com/settings/developers
# Authorization callback URL: http://localhost:8080/api/auth/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Optional overrides:
# GITHUB_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/callback
# GITHUB_OAUTH_SCOPE=read:user repo
# GITHUB_OAUTH_USER_AGENT=Committr-Backend
